#!/bin/sh

# Force a unified UTF-8 environment for all applications launched by X
export LANG="en_US.UTF-8"
export LANGUAGE="en_US:en"
export LC_CTYPE="en_US.UTF-8"
export LC_NUMERIC="en_US.UTF-8"
export LC_TIME="en_US.UTF-8"
export LC_COLLATE="en_US.UTF-8"
export LC_MONETARY="en_US.UTF-8"
export LC_MESSAGES="en_US.UTF-8"
export LC_PAPER="en_US.UTF-8"
export LC_NAME="en_US.UTF-8"
export LC_ADDRESS="en_US.UTF-8"
export LC_TELEPHONE="en_US.UTF-8"
export LC_MEASUREMENT="en_US.UTF-8"
export LC_IDENTIFICATION="en_US.UTF-8"
# CRITICAL: This overrides all specific LC_* settings and must be set early
export LC_ALL="en_US.UTF-8"

# Screen blanking / monitor power-off after 30 minutes idle (1800s).
# X-server screensaver (blank) timer + DPMS standby/suspend/off.
xset s 1800 1800
xset dpms 1800 1800 1800

# Keyboard layouts: English (default) + Hebrew in the LyX niqqud layout.
#   - Group 1 = us  -> default, plain English.
#   - Group 2 = il(lyx) -> Hebrew consonants on the base layer, niqqud on Shift
#     (e.g. Shift-j = hiriq, Shift-e = qamats). Shift never yields Latin.
#   - grp:shifts_toggle: press BOTH Shift keys together to flip languages.
# Layout state is global (a keyboard setting, not per-window).
setxkbmap -layout us,il -variant ,lyx -option grp:shifts_toggle

exec xmonad
