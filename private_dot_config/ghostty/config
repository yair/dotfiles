# ~/.config/ghostty/config — primary terminal emulator (replaces alacritty).
#
# IMPORTANT: ghostty does NOT support trailing/inline comments. Every comment
# must be on its own line -- otherwise ghostty reads the comment as part of the
# value and rejects the line (the "Configuration Errors" popup).
#
# Why ghostty: alacritty has no desktop-notification escape support. Ghostty
# renders OSC 777 -> a real OS desktop notification (dunst), carrying a remote
# Claude Code turn/permission message home. See ~/.local/bin/claude-turn-notify
# and tmux `allow-passthrough on`.

desktop-notifications = true

# Window chrome stripped for the xmonad tiling WM (no titlebar / tabs / buttons).
window-decoration = false
gtk-titlebar = false
window-show-tab-bar = never

# Each launch is its own window/process (xmonad-friendly).
gtk-single-instance = false

# No "really close?" confirmation popup.
confirm-close-surface = false

# Clipboard / selection -- classic X two-buffer model. With copy-on-select on,
# all of this is ghostty default behavior:
#   select text  -> copies to PRIMARY
#   middle-click  -> pastes PRIMARY
#   Shift+Insert  -> pastes PRIMARY (keyboard)
#   Ctrl+Shift+C  -> copies selection to CLIPBOARD
#   Ctrl+Shift+V  -> pastes CLIPBOARD
# PRIMARY and CLIPBOARD stay separate (copy-on-select does not touch CLIPBOARD).
copy-on-select = true
clipboard-read = allow
mouse-hide-while-typing = true

# Paste immediately -- no "this text looks unsafe" confirmation dialog. That
# protection (on by default) is what blocked middle-click pasting a selected
# line (newlines trip it). Off = behaves like every other app; you're trusted
# to know what you paste.
clipboard-paste-protection = false

# Generous scrollback; real "old command" recall is shell history.
scrollback-limit = 100000000

# Shell integration:
#   no-cursor             stop ghostty reshaping the cursor (it fought Claude Code's TUI)
#   ssh-env, ssh-terminfo  auto-handle the xterm-ghostty terminfo over ssh
shell-integration-features = no-cursor,title,path,ssh-env,ssh-terminfo

# Shift+Enter -> ESC then CR (ported from alacritty).
keybind = shift+enter=text:\x1b\r

# Pure black background.
background = 181825

# (Uncomment to match the tmux status bar instead -- note a theme sets its own
# background, overriding the line above:)
# theme = catppuccin-mocha
