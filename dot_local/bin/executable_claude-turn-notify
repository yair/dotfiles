#!/bin/sh
# claude-turn-notify — Claude Code Stop + Notification hook.
#
# Distributed identically to every machine via chezmoi; decides per-environment:
#   - Local / has a display:   desktop notification via notify-send (rich).
#   - Headless / remote (SSH): emit an OSC 777 desktop-notification escape. It
#     rides the pane tty -> tmux (allow-passthrough on) -> ssh -> the LOCAL
#     ghostty, which turns it into a real OS desktop notification (NOT text on
#     the remote screen). Carries the message text plus the host name.
#
# Wired to BOTH the Stop hook (turn ended) and the Notification hook (Claude
# paused for permission / idle input), so a remote agent stuck on a prompt
# still pings you.

proj=$(basename "${CLAUDE_PROJECT_DIR:-$PWD}")

# The Notification hook sends a "message" on stdin (e.g. "Claude needs your
# permission to use Bash"); the Stop hook does not. Read it only when stdin is
# a pipe, so a manual test run doesn't hang waiting on the keyboard.
message=""
if [ ! -t 0 ]; then
    message=$(python3 -c 'import sys, json
try: print(json.load(sys.stdin).get("message", ""))
except Exception: pass' 2>/dev/null)
fi

if [ -n "$message" ]; then
    body="$message ($proj)"
else
    body="Turn complete in $proj — waiting for input"
fi

# Local: rich desktop notification, done.
if [ -n "$DISPLAY" ] && command -v notify-send >/dev/null 2>&1; then
    notify-send 'Claude Code' "$body"
    exit 0
fi

# Headless: emit an OSC 777 desktop-notification escape toward the local
# terminal. ghostty (desktop-notifications on) renders it as a real popup via
# the OS notification daemon -- it is NOT printed to the remote screen.
host=$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo remote)
title="Claude @ $host"
# OSC 777 fields are ';'-separated; flatten ';' and newlines in the body.
body=$(printf '%s' "$body" | tr ';\r\n' ',  ')

emit() {
    if [ -n "$TMUX" ]; then
        # tmux passthrough: wrap the escape, doubling every ESC inside it.
        printf '\033Ptmux;\033\033]777;notify;%s;%s\033\033\\\033\\' "$title" "$body"
    else
        printf '\033]777;notify;%s;%s\033\\' "$title" "$body"
    fi
}

# Write to the first target that actually accepts it (the subshell-redirect
# tests the open, so a failed /dev/tty falls through cleanly instead of
# leaking an error): tmux pane tty -> controlling terminal -> stdout. The pane
# tty works even when Claude has captured our stdout.
pane_tty=""
if [ -n "$TMUX_PANE" ] && command -v tmux >/dev/null 2>&1; then
    pane_tty=$(tmux display-message -p -t "$TMUX_PANE" '#{pane_tty}' 2>/dev/null)
fi

if   [ -n "$pane_tty" ] && ( emit > "$pane_tty" ) 2>/dev/null; then :
elif ( emit > /dev/tty ) 2>/dev/null; then :
else emit
fi
